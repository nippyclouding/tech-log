# Copy this file to .env.prod on EC2 and replace every placeholder.

# Public origin used by CORS, OAuth redirects, and the admin "site view" link.
# Use http://EC2_PUBLIC_IP while testing, then https://your-domain.com after TLS is ready.
FRONTEND_ORIGIN=http://YOUR_EC2_PUBLIC_IP

# GitHub OAuth App callback URL must be:
#   http://YOUR_EC2_PUBLIC_IP/login/oauth2/code/github
# or, with TLS:
#   https://your-domain.com/login/oauth2/code/github
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

ADMIN_CONSOLE_USERNAME=admin
ADMIN_CONSOLE_PASSWORD=replace-with-long-random-password

POSTGRES_DB=techlog
POSTGRES_USER=techlog
POSTGRES_PASSWORD=replace-with-long-random-db-password

# Spring backend DB connection. Keep these aligned with POSTGRES_* above unless you change compose.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/techlog
SPRING_DATASOURCE_USERNAME=techlog
SPRING_DATASOURCE_PASSWORD=replace-with-long-random-db-password

# New post email notifications. For Gmail use an app password, not the account password.
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-account@example.com
MAIL_PASSWORD=replace-with-smtp-app-password
MAIL_FROM=your-smtp-account@example.com
MAIL_SITE_NAME=Tech Log
